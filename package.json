{
  "name": "orbit",
  "version": "0.1.0",
  "private": true,
  "description": "An independent GitHub-native agent operating system with AI budget controls, guarded token operations, and auditable memory.",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "cycle": "node src/agent/run.js",
    "demo:cycles": "node src/cli/demo-cycles.js",
    "health": "node src/cli/health.js",
    "lint": "node --check src/agent/*.js && node --check src/cli/*.js",
    "test": "node --test tests/*.test.js",
    "audit": "npm audit --omit=dev"
  },
  "keywords": [
    "github-actions",
    "autonomous-agent",
    "repo-agent",
    "ai-maintainer",
    "automation",
    "clanker",
    "base",
    "token"
  ],
  "license": "MIT",
  "dependencies": {
    "clanker-sdk": "^4.2.16",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.50.4"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.14"
  }
}
