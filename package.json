{
  "name": "orbit",
  "version": "0.1.0",
  "private": true,
  "description": "A GitHub-native infrastructure control plane for repos, agents, proofs, permissions, lifecycle, and wallet policy.",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "cycle": "node src/agent/run.js",
    "demo:cycles": "node src/cli/demo-cycles.js",
    "health": "node src/cli/health.js",
    "infrastructure": "node src/cli/infrastructure.js",
    "sdk": "node packages/orbit-sdk/cli.js",
    "orbit:query": "node src/cli/orbit-query.js",
    "orbit:adopter": "node src/cli/orbit-adopter.js",
    "orbit:launch-validate": "node src/cli/orbit-launch-validate.js",
    "orbit:preflight": "node src/cli/orbit-preflight.js",
    "lint": "node --check src/agent/*.js && node --check src/cli/*.js",
    "test": "node --test tests/*.test.js",
    "audit": "npm audit --omit=dev"
  },
  "keywords": [
    "github-actions",
    "agent-infrastructure",
    "repository-control-plane",
    "github-native",
    "agent-sdk",
    "proof-receipts",
    "wallet-policy",
    "automation",
    "permissions",
    "lifecycle"
  ],
  "license": "MIT",
  "dependencies": {
    "clanker-sdk": "^4.2.16",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.50.4"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.14"
  }
}
