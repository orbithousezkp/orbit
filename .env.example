# Orbit can run against any OpenAI-compatible chat completions endpoint.
# Keep live provider names, API bases, models, headers, and keys in private secrets.
ORBIT_AI_PROVIDER_KEYS={"private-route-1":"replace-with-key","private-route-2":"replace-with-key"}

# Optional full override. Add, remove, or reorder providers by changing this JSON.
# Prefer storing this full JSON as a GitHub Secret named ORBIT_AI_PROVIDERS for hosted runs.
ORBIT_AI_PROVIDERS=[
  {"name":"private-route-1","apiKeyEnv":"PRIVATE_ROUTE_1_API_KEY","apiBase":"https://provider.example/v1","chatPath":"/chat/completions","model":"private-model-1"},
  {"name":"private-route-2","apiKeyEnv":"PRIVATE_ROUTE_2_API_KEY","apiBase":"https://backup.example/v1","chatPath":"/chat/completions","model":"private-model-2","toolResultMode":"user_summary"}
]
PRIVATE_ROUTE_1_API_KEY=
PRIVATE_ROUTE_2_API_KEY=

# AI inference budgets. Orbit enforces these as terminal caps and falls back to
# the deterministic planner once exhausted. Operator-configured per deployment;
# see docs/wallet-policy.md for the policy model. Unset variables fail closed
# (no inference until configured).
ORBIT_AI_DAILY_BUDGET_USD=
ORBIT_AI_MONTHLY_BUDGET_USD=
ORBIT_AI_INPUT_USD_PER_MILLION=
ORBIT_AI_OUTPUT_USD_PER_MILLION=

# GitHub Actions provides this automatically when the project is hosted.
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repo
ORBIT_OWNER_USERNAME=owner
ORBIT_APPROVAL_ISSUE_LABEL=orbit:approval
ORBIT_APPROVAL_ACCEPTED_LABEL=orbit:approved
ORBIT_APPROVAL_REJECTED_LABEL=orbit:rejected

# Agent runtime controls.
ORBIT_MAX_STEPS=8
ORBIT_DRY_RUN=true
ORBIT_COMMIT_CHANGES=false
ORBIT_PUSH_CHANGES=false
# Local command execution is off by default. If enabled, entries must match exactly.
ORBIT_ALLOW_COMMANDS=false
ORBIT_COMMAND_ALLOWLIST=
ORBIT_FETCH_ALLOWED_DOMAINS=github.com,docs.github.com,clanker.world,clanker.gitbook.io,base.org,docs.base.org,openai.com,platform.openai.com
ORBIT_FETCH_MAX_BYTES=80000
ORBIT_FETCH_TIMEOUT_MS=12000
ORBIT_ALLOW_RISKY_FETCH=false
ORBIT_WEB_SEARCH_ENDPOINT=
ORBIT_WEB_SEARCH_KEY=

# Native token configuration. Keep private keys in GitHub Secrets, never in source.
ORBIT_TOKEN_NAME=Orbit
ORBIT_TOKEN_SYMBOL=ORBIT
ORBIT_TOKEN_DESCRIPTION=Orbit is a GitHub-native autonomous agent that funds its own work through public rewards.
ORBIT_TOKEN_IMAGE_URI=
ORBIT_TOKEN_ADMIN_ADDRESS=
ORBIT_TREASURY_ADDRESS=
ORBIT_OPERATOR_REVENUE_ADDRESS=
ORBIT_OPERATOR_REVENUE_BPS=
ORBIT_BASE_RPC_URL=
ORBIT_WALLET_PRIVATE_KEY=
ORBIT_ENABLE_TOKEN_LAUNCH=false
ORBIT_ENABLE_REVENUE_CLAIMS=false
ORBIT_REVENUE_CLAIM_INTERVAL_DAYS=7
ORBIT_REVENUE_PERFORMANCE_WINDOW_DAYS=7
ORBIT_REVENUE_MIN_COMPLETED_CYCLES=3
ORBIT_REVENUE_MIN_PRODUCTIVE_CYCLES=1
ORBIT_REVENUE_MIN_PRODUCTIVE_RATIO=0.25
ORBIT_TOKEN_VAULT_PERCENTAGE=10
ORBIT_TOKEN_VAULT_LOCKUP_DAYS=30
ORBIT_TOKEN_VAULT_VESTING_DAYS=30
ORBIT_DEV_BUY_ETH=0

# Public site configuration (Vite reads these at build time, exposed to the
# client as `import.meta.env.VITE_*`). Leave VITE_ORBIT_CA blank until ready
# to publish; the footer renders a copy-able placeholder either way.
VITE_ORBIT_CA=
VITE_ORBIT_GITHUB_URL=https://github.com/orbit-house
VITE_ORBIT_FARCASTER_URL=https://warpcast.com/orbit-house
