# ============================================================
# .env — local dev only. CONTAINS NO SECRETS. (D-021)
# ============================================================
#
# This file is a TEMPLATE. Copy to .env (gitignored) and fill ONLY
# the public-config values below. Real secrets — API keys, private
# keys, signer UUIDs, npm tokens — NEVER go in .env. They live in:
#
#   gh secret set NAME --body "..."          # GitHub Secrets (CI)
#   gh variable set NAME --body "..."        # GitHub Variables (public-ish)
#
# Defense in depth: even if .env contains a real secret by mistake,
# the tool-surface path-normalizer refuses any read_file({path:".env"})
# (Patch Set AF). But the project's posture is that .env should not
# carry that risk in the first place.
#
# Run `npm run env:check` after editing to confirm no secret-shaped
# content slipped in.
# ============================================================


# --- 1 / public config — safe in .env -----------------------

# Owner identity (already public — your github handle).
ORBIT_OWNER_USERNAME=owner

# GitHub repository reference (org/repo). Public.
GITHUB_REPOSITORY=owner/repo

# Approval-flow labels. Configuration, no secrecy.
ORBIT_APPROVAL_ISSUE_LABEL=orbit:approval
ORBIT_APPROVAL_ACCEPTED_LABEL=orbit:approved
ORBIT_APPROVAL_REJECTED_LABEL=orbit:rejected

# Agent runtime controls (public — describe behavior, not access).
ORBIT_MAX_STEPS=8
ORBIT_DRY_RUN=true
ORBIT_COMMIT_CHANGES=false
ORBIT_PUSH_CHANGES=false
ORBIT_ALLOW_COMMANDS=false
ORBIT_COMMAND_ALLOWLIST=

# AI budget caps (numbers, no access).
ORBIT_AI_DAILY_BUDGET_USD=
ORBIT_AI_MONTHLY_BUDGET_USD=
ORBIT_AI_INPUT_USD_PER_MILLION=
ORBIT_AI_OUTPUT_USD_PER_MILLION=

# Web fetch allowlist (public configuration).
ORBIT_FETCH_ALLOWED_DOMAINS=github.com,docs.github.com,clanker.world,clanker.gitbook.io,base.org,docs.base.org,openai.com,platform.openai.com
ORBIT_FETCH_MAX_BYTES=80000
ORBIT_FETCH_TIMEOUT_MS=12000
ORBIT_ALLOW_RISKY_FETCH=false

# Public site bundle (Vite ships these in the browser JS — by
# definition, anything VITE_* is PUBLIC the moment you build).
VITE_ORBIT_CA=
VITE_ORBIT_GITHUB_URL=https://github.com/orbit-house
VITE_ORBIT_FARCASTER_URL=https://warpcast.com/orbit-house


# --- 2 / SECRETS — NEVER PUT REAL VALUES IN .env -----------
#
# Listed here as a MANIFEST so you know what CI needs. Real values
# go in GitHub Secrets (via `gh secret set NAME --body "..."`).
# `npm run env:check` will fail if any of these names appear in
# .env with a non-empty value.
#
# ORBIT_AI_PROVIDER_KEYS         # gh secret — JSON map { providerName: apiKey }
# ORBIT_AI_PROVIDERS             # gh secret — JSON array of provider definitions
# ORBIT_WEB_SEARCH_KEY           # gh secret — optional web search API key
# ORBIT_WALLET_PRIVATE_KEY       # gh secret — signs cycle proofs (D-006)
# ORBIT_FARCASTER_NEYNAR_API_KEY # gh secret — Farcaster caster credential
# ORBIT_FARCASTER_SIGNER_UUID    # gh secret — Farcaster signer UUID
# ORBIT_SPAWN_TOKEN              # gh secret — PAT for child-repo creation (D-020)
# NPM_TOKEN                      # gh secret — npm automation token (publish workflow)
# GITHUB_TOKEN                   # provided automatically by GitHub Actions; do not set
#
# Variables (less sensitive but still gh-managed, not .env):
#
# ORBIT_AGENT_SIGNER             # gh variable — the public address matching the wallet key
# ORBIT_MAINTAINERS              # gh variable — comma-separated handles (multi-maintainer quorum)
# ORBIT_SPAWN_ORG                # gh variable — target org for spawned children
